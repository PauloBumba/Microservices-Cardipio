# ─────────────────────────────────────────────────────────────────────────────
# Copie para .env e preencha os valores reais
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────
# 1. Fale com @BotFather no Telegram → /newbot → copie o token
# 2. Adicione o bot ao grupo/canal e mande uma mensagem
# 3. Acesse: https://api.telegram.org/bot<TOKEN>/getUpdates
#    e copie o "id" dentro de "chat"
TELEGRAM_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff1234567890
TELEGRAM_CHAT_ID=-1001234567890

# ── WhatsApp — Evolution API ──────────────────────────────────────────────────
# Após subir o container evolution-api:
# 1. Acesse http://localhost:8081 → crie a instância "cardipio"
# 2. Escaneie o QR Code com o WhatsApp
# 3. A API Key é a que você definiu abaixo
EVOLUTION_API_KEY=minha-api-key-super-secreta
# Números no formato DDI+DDD+Número (sem + ou espaços)
WHATSAPP_NUMBERS=5549999999999,5549888888888

# ── Email — Gmail ─────────────────────────────────────────────────────────────
# Use App Password do Google (não a senha normal):
# Google Account → Segurança → Verificação em 2 etapas → Senhas de app
EMAIL_USERNAME=seu_email@gmail.com
EMAIL_PASSWORD=abcd efgh ijkl mnop
EMAIL_TO_ADDRESSES=paulo@empresa.com,devops@empresa.com

# ── Webhook secret (mesmo valor no grafana-alerts.yaml) ──────────────────────
WEBHOOK_SECRET=TROQUE_POR_UM_TOKEN_SEGURO
