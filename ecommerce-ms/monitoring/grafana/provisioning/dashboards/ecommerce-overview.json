      "title": "Error Rate % (4xx+5xx)",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "100 * sum(rate(http_requests_received_total{code=~\"4..|5..\"}[1m])) / sum(rate(http_requests_received_total[1m]))",
        "legendFormat": "error %",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
